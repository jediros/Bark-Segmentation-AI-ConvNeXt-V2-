{
    "name": "Wood Segmentation CPU",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--shm-size", "8gb",
        "--network", "host"
    ],
    // Mount your local data folder into the container.
    // Place your dataset at ./data relative to the project root,
    // or update the source path to match your local data location.
    "mounts": [
        "source=${localWorkspaceFolder}/data,target=/workspaces/Bark_AI/data,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3.10"
            }
        }
    },
    "remoteUser": "root"
}