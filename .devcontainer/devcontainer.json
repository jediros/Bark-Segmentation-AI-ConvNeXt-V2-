{
    "name": "Wood Segmentation CPU",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--shm-size", "8gb",
        "--network", "host"
    ],
    // --- ESTA ES LA PARTE CLAVE ---
    "mounts": [
        "source=/home/jedi-ai/AI/data/bark_images/all_images_tag,target=/workspaces/Bark_AI/data,type=bind,consistency=cached"
    ],
    // ------------------------------
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3.10"
            }
        }
    },
    "remoteUser": "root"
}